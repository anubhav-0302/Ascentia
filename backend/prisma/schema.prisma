generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Organization {
  id              Int      @id @default(autoincrement())
  name            String   @unique
  code            String?
  subscriptionPlan String? @default("free")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  employees        Employee[]
  leaveRequests    LeaveRequest[]
  timesheets       Timesheet[]
  performanceCycles PerformanceCycle[]
  salaryComponents SalaryComponent[]
  documents        Document[]
  roleConfigs      RoleConfig[]
  permissionAudits PermissionAudit[]
  auditLogs        AuditLog[]
  
  @@index([isActive])
  @@index([code])
}

model Employee {
  id                  Int                     @id @default(autoincrement())
  organizationId      Int                      @default(1)
  name                String
  email               String                  @unique
  password            String?
  jobTitle            String
  department          String
  location            String
  status              String                  @default("active")
  role                String                  @default("employee")
  lastLogin           DateTime?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  createdBy           Int?
  needsPasswordChange Boolean                 @default(false)
  profilePicture      String?
  phone               String?
  address             String?
  twoFactorEnabled    Boolean                 @default(false)
  twoFactorSecret     String?
  managerId           Int?
  settings            Json?
  manager             Employee?               @relation("EmployeeManager", fields: [managerId], references: [id])
  directReports       Employee[]              @relation("EmployeeManager")
  organization        Organization             @relation(fields: [organizationId], references: [id])
  ActivityMaster      ActivityMaster[]
  documents           Document[]
  salaries            EmployeeSalary[]
  leaveRequests       LeaveRequest[]
  passwordChanges     PasswordChangeHistory[]
  passwordChangesMade PasswordChangeHistory[] @relation("PasswordChanger")
  goals               PerformanceGoal[]       @relation("EmployeeGoals")
  reviews             PerformanceReview[]
  writtenReviews      PerformanceReview[]     @relation("PerformanceReviewer")
  permissionAuditLogs PermissionAudit[]
  timesheets          Timesheet[]
  approvedTimesheets  Timesheet[]             @relation("TimesheetApprover")
  
  @@index([organizationId])
  @@index([email, organizationId])
}

model PasswordChangeHistory {
  id         Int      @id @default(autoincrement())
  employeeId Int
  changedAt  DateTime @default(now())
  changedBy  Int
  reason     String?
  employee   Employee @relation(fields: [employeeId], references: [id])
  changer    Employee @relation("PasswordChanger", fields: [changedBy], references: [id])

  @@index([employeeId])
  @@index([changedAt])
}

model LeaveRequest {
  id            Int      @id @default(autoincrement())
  organizationId Int     @default(1)
  employeeId    Int
  type          String
  startDate     DateTime
  endDate       DateTime
  reason        String
  status        String   @default("Pending")
  createdAt     DateTime @default(now())
  employee      Employee @relation(fields: [employeeId], references: [id])
  organization  Organization @relation(fields: [organizationId], references: [id])
  
  @@index([organizationId])
}

model Timesheet {
  id            Int       @id @default(autoincrement())
  organizationId Int      @default(1)
  employeeId    Int
  date          DateTime
  hours         Float
  description   String?
  activityId    Int?
  status        String    @default("Pending")
  approvedBy    Int?
  approvedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  ActivityMaster ActivityMaster? @relation(fields: [activityId], references: [id])
  employee      Employee  @relation(fields: [employeeId], references: [id])
  approver      Employee? @relation("TimesheetApprover", fields: [approvedBy], references: [id])
  organization  Organization @relation(fields: [organizationId], references: [id])
  
  @@index([organizationId])
}

model PerformanceCycle {
  id            Int                 @id @default(autoincrement())
  organizationId Int                @default(1)
  name          String
  description   String?
  startDate     DateTime
  endDate       DateTime
  status        String              @default("Active")
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  organization  Organization        @relation(fields: [organizationId], references: [id])
  goals         PerformanceGoal[]
  reviews       PerformanceReview[]
  
  @@index([organizationId])
}

model PerformanceGoal {
  id          Int                 @id @default(autoincrement())
  cycleId     Int
  employeeId  Int
  title       String
  description String
  targetDate  DateTime
  status      String              @default("Active")
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  kras        KRA[]
  cycle       PerformanceCycle    @relation(fields: [cycleId], references: [id])
  employee    Employee            @relation("EmployeeGoals", fields: [employeeId], references: [id])
  reviews     PerformanceReview[]
}

model KRA {
  id            Int             @id @default(autoincrement())
  goalId        Int
  title         String
  description   String?
  targetValue   String?
  actualValue   String?
  weightage     Float           @default(1.0)
  status        String          @default("Pending")
  dueDate       DateTime?
  completedDate DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  goal          PerformanceGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

model PerformanceReview {
  id         Int               @id @default(autoincrement())
  cycleId    Int?
  goalId     Int?
  employeeId Int
  reviewerId Int
  type       String
  rating     Int
  feedback   String?           @map("comments")
  status     String            @default("Pending")
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  cycle      PerformanceCycle? @relation(fields: [cycleId], references: [id])
  goal       PerformanceGoal?  @relation(fields: [goalId], references: [id])
  employee   Employee          @relation(fields: [employeeId], references: [id])
  reviewer   Employee          @relation("PerformanceReviewer", fields: [reviewerId], references: [id])
}

model SalaryComponent {
  id               Int              @id @default(autoincrement())
  organizationId   Int              @default(1)
  name             String
  type             String
  category         String
  amount           Float
  isPercentage     Boolean          @default(false)
  isTaxable        Boolean          @default(true)
  status           String           @default("Active")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  organization     Organization     @relation(fields: [organizationId], references: [id])
  employeeSalaries EmployeeSalary[]
  
  @@index([organizationId])
}

model EmployeeSalary {
  id            Int             @id @default(autoincrement())
  employeeId    Int
  componentId   Int
  amount        Float
  effectiveDate DateTime
  endDate       DateTime?
  status        String          @default("Active")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  employee      Employee        @relation(fields: [employeeId], references: [id])
  component     SalaryComponent @relation(fields: [componentId], references: [id])
}

model Document {
  id            Int      @id @default(autoincrement())
  organizationId Int     @default(1)
  employeeId    Int
  fileName      String
  originalName  String
  fileUrl       String
  fileSize      Int
  uploadedAt    DateTime @default(now())
  employee      Employee @relation(fields: [employeeId], references: [id])
  organization  Organization @relation(fields: [organizationId], references: [id])

  @@index([employeeId])
  @@index([organizationId])
}

model RoleConfig {
  id            Int               @id @default(autoincrement())
  organizationId Int              @default(1)
  name          String            @unique
  description   String?
  isCustom      Boolean           @default(false)
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  organization  Organization     @relation(fields: [organizationId], references: [id])
  permissions   Permission[]
  auditLogs     PermissionAudit[]

  @@index([name])
  @@index([organizationId])
}

model Permission {
  id        Int        @id @default(autoincrement())
  roleId    Int
  module    String
  action    String
  isEnabled Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  role      RoleConfig @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module, action])
  @@index([roleId])
  @@index([module])
}

model PermissionAudit {
  id            Int        @id @default(autoincrement())
  organizationId Int       @default(1)
  roleId        Int
  changedBy     Int
  module        String
  action        String
  previousValue Boolean
  newValue      Boolean
  reason        String?
  changedAt     DateTime   @default(now())
  organization  Organization @relation(fields: [organizationId], references: [id])
  changedByUser Employee   @relation(fields: [changedBy], references: [id])
  role          RoleConfig @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@index([roleId])
  @@index([changedBy])
  @@index([changedAt])
  @@index([organizationId])
}

model ActivityMaster {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  createdBy   Int
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime
  Employee    Employee    @relation(fields: [createdBy], references: [id])
  Timesheet   Timesheet[]

  @@index([isActive])
}

model AuditLog {
  id            Int        @id @default(autoincrement())
  organizationId Int       @default(1)
  userId        Int
  action        String
  entityType    String
  entityId      Int?
  changes       String?
  ipAddress     String?
  userAgent     String?
  timestamp     DateTime   @default(now())
  organization  Organization @relation(fields: [organizationId], references: [id])

  @@index([userId])
  @@index([timestamp])
  @@index([organizationId])
}
