{
  "name": "backend",
  "version": "1.0.0",
  "description": "Ascentia Backend",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --ignore 'data/*.json' --ignore 'dev.db' index.js",
    "db:migrate": "node scripts/safe-migrate.js dev --name",
    "db:push": "echo '⚠️  WARNING: Use npm run db:migrate instead to prevent data loss!' && node scripts/safe-migrate.js push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:reset": "echo '⚠️  WARNING: This will reset your database! Creating backup first...' && npm run backup:create pre-reset && prisma migrate reset --force",
    "db:pull": "prisma db pull",
    "backup:create": "node scripts/backup-system.js create",
    "backup:list": "node scripts/backup-system.js list",
    "backup:restore": "node scripts/backup-system.js restore",
    "backup:schedule": "node scripts/backup-system.js schedule",
    "protect:run": "node scripts/data-protection.js",
    "protect:integrity": "node scripts/data-protection.js integrity",
    "protect:validate": "node scripts/data-protection.js validate",
    "recover:list": "node scripts/disaster-recovery.js list",
    "recover:verify": "node scripts/disaster-recovery.js verify",
    "recover:restore": "node scripts/disaster-recovery.js restore",
    "recover:test": "node scripts/disaster-recovery.js test",
    "seed": "node prisma/seed.js",
    "test:regression": "node tests/regression-api.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.0",
    "express-validator": "^7.3.2",
    "form-data": "^4.0.5",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "node-fetch": "^2.7.0",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "prisma": "^7.6.0"
  }
}
