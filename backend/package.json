{
  "name": "backend",
  "version": "1.0.0",
  "description": "Ascentia Backend",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon index.js",
    "db:migrate": "prisma migrate dev --name init --url=postgresql://postgres:postgres@localhost:5433/ascentia",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio --url=postgresql://postgres:postgres@localhost:5433/ascentia",
    "db:reset": "prisma migrate reset --force --url=postgresql://postgres:postgres@localhost:5433/ascentia",
    "db:pull": "prisma db pull --url=postgresql://postgres:postgres@localhost:5433/ascentia",
    "db:push": "prisma db push --url=postgresql://postgres:postgres@localhost:5433/ascentia",
    "seed": "node prisma/seed.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "prisma": "^7.6.0"
  }
}
