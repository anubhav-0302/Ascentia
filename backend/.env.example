# ============================================================
# ASCENTIA HRMS - ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================
# Copy this file to `.env` and fill in the values.
# NEVER commit the real `.env` file to version control.
# ============================================================

# ---------- DATABASE ----------
DATABASE_URL="file:./dev.db"

# ---------- SERVER ----------
PORT=5000
NODE_ENV=development
# Comma-separated list of allowed origins for CORS, or * for any
CORS_ORIGIN=*

# ---------- AUTHENTICATION ----------
# IMPORTANT: In production the server REFUSES to boot if JWT_SECRET is:
#   - missing
#   - shorter than 32 characters
#   - one of the known demo values (see config/env.js)
# Generate a strong one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET="change-this-to-a-long-random-string-in-production"
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

# ---------- DEFAULT SEED USERS ----------
# These users are auto-created on first startup / after a DB reset.
# Change the default passwords after first login in production!

# Super Admin (not tied to any organization, full platform access)
SUPERADMIN_NAME="Super Admin"
SUPERADMIN_EMAIL=superadmin@ascentia.com
SUPERADMIN_PASSWORD=superadmin123

# Default Organization Admin (tied to the default organization)
ADMIN_NAME="Admin User"
ADMIN_EMAIL=admin@ascentia.com
ADMIN_PASSWORD=admin123

# Default Employee (demo account)
EMPLOYEE_NAME="John Doe"
EMPLOYEE_EMAIL=employee@ascentia.com
EMPLOYEE_PASSWORD=123456

# ---------- DEFAULT ORGANIZATION ----------
DEFAULT_ORG_NAME="Default Organization"
DEFAULT_ORG_PLAN=free

# ---------- BACKUP & DATA PROTECTION ----------
BACKUP_DIR=./backups
MAX_BACKUPS=30
BACKUP_SCHEDULE_CRON="0 2 * * *"
BACKUP_COMPRESS=true

# ---------- FILE UPLOADS ----------
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# ---------- LOGGING ----------
LOG_DIR=./logs
LOG_LEVEL=info
